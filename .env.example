# Credential Injection
# Copy this to .env (gitignored) and fill in your keys

# OpenCode
OPENCODE_SERVER_PASSWORD=

# SSH Default Credentials (use with caution)
# SSH_KEY_PATH=~/.ssh/id_rsa
# SSH_DEFAULT_USER=root

# Kubernetes
# KUBECONFIG=~/.kube/config

# Databases
# PG_CONNECTION_STRING=postgresql://user:pass@localhost:5432/db

# Monitoring
# PROMETHEUS_URL=http://localhost:9090
# DATADOG_API_KEY=
# DATADOG_APP_KEY=

# ITSM / CMDB
# SERVICENOW_INSTANCE=
# SERVICENOW_USER=
# SERVICENOW_PASSWORD=
# JIRA_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# IT Documentation
# CONFLUENCE_URL=
# CONFLUENCE_API_TOKEN=
