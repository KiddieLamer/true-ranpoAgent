{
  "name": "true-ranpo-agent",
  "version": "0.1.1",
  "description": "AI-Powered Scrum Team — 31 specialized IT agents from PRD to delivery",
  "main": "./dist/index.js",
  "types": "./dist/packages/true-ranpo/src/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "skills",
    "true-ranpoAgent.json",
    "opencode.json",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./packages/true-ranpo/src/index.ts --outdir ./dist --target bun --format esm --external @opencode-ai/plugin --external zod && tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.0",
    "typescript": "^6.0.0"
  },
  "license": "MIT",
  "keywords": [
    "opencode",
    "plugin",
    "scrum",
    "agents",
    "ai-team",
    "project-management",
    "it-team"
  ]
}
